# Node.js 依赖
node_modules/

# Next.js 构建输出
.next/

# 静态导出目录（如果有用到 next export）
out/

# 环境变量文件
.env.local
.env.development.local
.env.test.local
.env.production.local

# macOS 系统文件
.DS_Store

# 日志文件
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# 编辑器配置文件（根据你用的编辑器可以增删）
.vscode/
.idea/

# 其他系统或工具产生的文件
*.swp

# 忽略 npm 锁定文件
package-lock.json
# 忽略备份文件
*.bak
package-lock.json.bak

# Cursor：默认忽略，但允许将规则/技能纳入版本管理
.cursor/*
!.cursor/
!.cursor/rules/
!.cursor/rules/**
!.cursor/skills/
!.cursor/skills/**
