    "notify:send:test": "OPENCLAW_NOTIFY_DRY_RUN=1 OPENCLAW_FEISHU_TARGET=${OPENCLAW_FEISHU_TARGET:-dry-run-target} bash scripts/notify-feishu-update.sh commit"
  },
  "dependencies": {
    "@ant-design/icons": "^6.0.0",
    "@ant-design/plots": "^2.6.5",
    "@antv/g2plot": "^2.4.35",
    "antd": "^5.26.7",
    "next": "15.4.8",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "eslint": "^9",
    "eslint-config-next": "15.4.8",
    "playwright": "^1.59.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
