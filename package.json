{
  "name": "my-product-prototype",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "ai:validate": "node scripts/ai/validate-work-item.mjs",
    "ai:check": "npm run ai:validate && npm run lint",
